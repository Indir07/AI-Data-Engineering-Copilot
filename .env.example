# ---------------------------------------------------------------------------
# AI Data Engineering Copilot — example environment configuration
# Copy to `.env` and adjust. NEVER commit a real .env file.
# ---------------------------------------------------------------------------

# --- Application ---
APP_ENV=local                       # local | dev | prod
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# --- LLM provider (model-agnostic layer) ---
# provider: ollama (default, free & local) | openai_compatible
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
# Default is a code-specialised model; swap freely without code changes.
LLM_MODEL=qwen2.5-coder:7b-instruct
LLM_FALLBACK_MODEL=llama3.1:8b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=120

# --- Embeddings (RAG) ---
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# --- Vector store ---
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION=copilot_docs
RAG_TOP_K=5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# --- Relational storage ---
# Metadata/history DB. SQLite for local; Postgres for compose/cloud.
DATABASE_URL=sqlite:///./data/copilot.db
# DATABASE_URL=postgresql+psycopg://copilot:copilot@postgres:5432/copilot

# --- Analytical engine ---
DUCKDB_PATH=/app/data/analytics.duckdb

# --- Uploads ---
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_MB=25
