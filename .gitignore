# ---------------------------------------------------------------------------
# AI Data Engineering Copilot — .gitignore
# ---------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
.python-version

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Vector store / local data artifacts
data/chroma/
data/uploads/
*.duckdb
*.sqlite
*.sqlite3
*.db

# Models / large binaries
*.gguf
*.bin
models/

# Jupyter
.ipynb_checkpoints/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Sandbox stray files (cannot be removed from a mounted volume)
_t2

# Docker
*.log

# Local Claude settings
.claude/
